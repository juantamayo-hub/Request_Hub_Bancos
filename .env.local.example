# ─── Supabase ────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key: NEVER expose to the browser.
# Used in Route Handlers (server-side) for privileged operations & audit log.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Auth ────────────────────────────────────────────────────────────────────
# Domain that is allowed to sign in (e.g. huspy.io)
NEXT_PUBLIC_ALLOWED_DOMAIN=huspy.io

# ─── App ─────────────────────────────────────────────────────────────────────
# Used for building absolute URLs in notifications. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Notifications (optional – stub if omitted) ───────────────────────────────
# Slack incoming webhook URL (simpler than Bot Token for MVP)
SLACK_WEBHOOK_URL=

# OR Slack Bot Token + Channel ID (if using Web API)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Email provider: "resend" | leave blank to stub
EMAIL_PROVIDER=
RESEND_API_KEY=
EMAIL_FROM=noreply@huspy.io
